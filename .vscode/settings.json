{
  "comments.maxHeight": false,
  "editor.minimap.enabled": false,
  "editor.formatOnSave": false,
  
  // Enable per-language
  "[json]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.formatOnSave": true,
    // Offload formatting to Prettier so the TS server isn't stressed on save
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  "typescript.tsserver.maxTsServerMemory": 3072,

  "workbench.sideBar.location": "right",
  "codetour.promptForWorkspaceTours": false,
  "codetour.showMarkers": false,
  "codetour.customTourDirectory": ".auth0/lab/guides",
  "githubPullRequests.ignoredPullRequestBranches": [
    "main"
  ],
  "files.watcherExclude": {
    "**/.next/**": true,
    "**/node_modules/**": true,
    "**/.tsbuildinfo": true
  },
  "search.exclude": {
    "**/.next/**": true,
    "**/node_modules/**": true,
    "**/.tsbuildinfo": true
  }
}